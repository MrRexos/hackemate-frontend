# Copia a `.env.local` i omple els valors (no commitis `.env.local`).

# Supabase (obligatori per llegir distribució des de la BD)
VITE_SUPABASE_URL=
# Clau anon o publishable (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=

# Opcional: taula plana amb route_id. Si NO la defines, es fan servir les taules d’empresa
# (cabecera_transporte, horarios_entrega, detalle_entrega, materiales).
# VITE_SUPABASE_DISTRIBUCIO_TABLE=distribucio_linies
#
# Columnes / taules (només si els noms reals difereixen dels per defecte):
# VITE_SUPABASE_TABLE_CABECERA=cabecera_transporte
# VITE_SUPABASE_TABLE_HORARIOS=horarios_entrega
# VITE_SUPABASE_TABLE_DETALLE=detalle_entrega
# VITE_SUPABASE_TABLE_MATERIALES=materiales
# VITE_SUPABASE_TABLE_CLIENTES=clientes
# VITE_SUPABASE_COL_CABECERA_RUTA_REF=codigo_ruta
# VITE_SUPABASE_COL_CABECERA_PK=
# VITE_SUPABASE_COL_CABECERA_ZONA=id_zona
# VITE_SUPABASE_COL_HORARIOS_FK_CABECERA=id_cabecera
# VITE_SUPABASE_COL_HORARIOS_ORDEN=orden
# VITE_SUPABASE_COL_DETALLE_FK_CABECERA=id_cabecera
# VITE_SUPABASE_COL_CLIENTES_PK=id
# VITE_SUPABASE_COL_CLIENTES_ZONA=id_zona
# VITE_SUPABASE_COL_MATERIALES_PK=id
# Nom del producte a la línia de comanda (detalle); opcional si la columna és estranya:
# VITE_SUPABASE_COL_DETALLE_DESCRIPCIO_PRODUCTE=texto_material
#
# Catàleg d’articles (opcional): si el detall té articulo_id cap a una altra taula amb el nom comercial:
# VITE_SUPABASE_TABLE_ARTICULOS=articulos
# VITE_SUPABASE_COL_ARTICULOS_PK=id

# VITE_API_URL=
# VITE_GOOGLE_MAPS_API_KEY=
